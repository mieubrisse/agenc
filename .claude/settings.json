{
    "permissions": {
        "allow": [
            "Read(./**)",
            "Edit(./**)",
            "Write(./**)",
            "Glob(./**)",
            "Grep(./**)",
            "Read(~/.gitconfig)",
            "Read(~/.claude.json)",
            "Read(~/.claude/.claude.json)",
            "Read(~/.agenc/**)",
            "Glob(~/.agenc/**)",
            "Grep(~/.agenc/**)",
            "Read(~/.beads_rust/agenc/**)",
            "Edit(~/.beads_rust/agenc/**)",
            "Write(~/.beads_rust/agenc/**)",
            "Glob(~/.beads_rust/agenc/**)",
            "Grep(~/.beads_rust/agenc/**)",
            "Bash(br:*)",
            "Bash(go:*)",
            "Bash(./agenc:*)",
            "Bash(tree:*)",
            "Bash(make:*)",
            "Bash(find:*)",
            "Bash(gofmt:*)",
            "Bash(golangci-lint:*)",
            "Bash(sqlite3:*)",
            "Bash(rm:*)",
            "Bash(cp:*)",
            "Bash(mv:*)",
            "Bash(tmux list-panes:*)",
            "Bash(tmux display-message:*)",
            "Bash(tmux list-windows:*)",
            "Bash(agenc server logs print:*)"
        ],
        "deny": [
            "Read(./.env)",
            "Read(./.env.*)",
            "Read(./secrets/**)",
            "Bash(rm -rf:*)",
            "Bash(sudo:*)",
            "Bash(git commit --no-verify:*)",
            "Skill(agenc-engineer:*)"
        ]
    },
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/enforce-br-no-db.sh"
                    }
                ]
            }
        ]
    }
}

