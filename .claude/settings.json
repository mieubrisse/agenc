{
    "permissions": {
        "allow": [
            "Read(.)",
            "Read(./**)",
            "Edit(./**)",
            "Write(./**)",
            "Glob(.)",
            "Glob(./**)",
            "Grep(.)",
            "Grep(./**)",
            "Read(~/.gitconfig)",
            "Read(~/.claude.json)",
            "Read(~/.claude/.claude.json)",
            "Read(~/.agenc/**)",
            "Glob(~/.agenc/**)",
            "Grep(~/.agenc/**)",
            "Bash(bd:*)",
            "Bash(go:*)",
            "Bash(./_build/agenc:*)",
            "Bash(./_build/agenc-test:*)",
            "Bash(tree:*)",
            "Bash(make:*)",
            "Bash(find:*)",
            "Bash(gofmt:*)",
            "Bash(golangci-lint:*)",
            "Bash(sqlite3:*)",
            "Bash(rm:*)",
            "Bash(cp:*)",
            "Bash(mv:*)",
            "Bash(tmux list-panes:*)",
            "Bash(tmux list-sessions:*)",
            "Bash(tmux capture-pane:*)",
            "Bash(tmux display-message:*)",
            "Bash(tmux list-windows:*)",
            "Bash(agenc server logs print:*)"
        ],
        "ask": [
            "Bash(bd init)",
            "Bash(bd init *)"
        ],
        "deny": [
            "Read(./.env)",
            "Read(./.env.*)",
            "Read(./secrets/**)",
            "Bash(rm -rf:*)",
            "Bash(sudo:*)",
            "Bash(git commit --no-verify:*)",
            "Skill(agenc-engineer:*)"
        ]
    },
    "sandbox": {
        "filesystem": {
            "allowWrite": ["//tmp", "//private/tmp/claude"]
        },
        "excludedCommands": ["bd", "dolt"],
        "network": {
            "allowLocalBinding": true,
            "allowedDomains": ["127.0.0.1", "localhost"],
            "allowUnixSockets": ["//tmp/claude", "//private/tmp/claude"]
        }
    },
    "hooks": {
        "SessionStart": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bd prime"
                    }
                ]
            }
        ],
        "PreCompact": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bd prime"
                    }
                ]
            }
        ]
    }
}

